#!/bin/sh
# Prevent direct pushes to the main branch.
# All changes must go through a Pull Request.

protected_branch="main"

while read local_ref local_sha remote_ref remote_sha; do
  if echo "$remote_ref" | grep -q "refs/heads/$protected_branch"; then
    echo ""
    echo "🚫 Direct push to '$protected_branch' is not allowed."
    echo ""
    echo "   Use a feature branch and open a Pull Request:"
    echo "   git checkout -b feat/your-branch-name"
    echo "   git push origin feat/your-branch-name"
    echo ""
    exit 1
  fi
done

exit 0
